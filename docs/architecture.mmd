%% System architecture — render at https://mermaid.live or in VS Code Mermaid preview
flowchart LR
    subgraph Users["User access (synthetic)"]
        WG[workload-generator<br/>Zipfian + shifting hot-set]
    end

    subgraph Bus["Event Bus"]
        K[(Apache Kafka<br/>topic: access-logs<br/>KRaft mode)]
    end

    subgraph Engine["placement-engine — Apache Spark (local mode)"]
        SS[Spark Streaming<br/>windowed aggregation]
        EMA[EMA baseline<br/>popularity score]
        ML[Spark MLlib<br/>demand prediction]
        PL[Placement engine<br/>promote / evict]
        SV[Serve path<br/>hit vs miss + latency]
    end

    subgraph Edge["EDGE tier (fast, near user)"]
        R[(Redis cache<br/>~2 ms)]
    end

    subgraph Cloud["CLOUD tier (far, large)"]
        H[(Hadoop HDFS<br/>+80 ms WAN<br/>auto-fallback: local store)]
    end

    DB[dashboard<br/>Streamlit :8501]

    WG -- access events --> K
    K -- micro-batches --> SS
    SS --> EMA --> PL
    SS --> ML --> PL
    PL -- promote hot data --> R
    PL -- evict cold data --> H
    SV -- HIT --> R
    SV -- MISS (read + promote) --> H
    K -- serve --> SV
    SS -. metrics .-> R
    PL -. metrics .-> R
    SV -. metrics .-> R
    R --> DB
