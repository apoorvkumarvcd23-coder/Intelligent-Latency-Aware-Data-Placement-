# Project-wide build/runtime variables consumed by docker-compose.yml
COMPOSE_PROJECT_NAME=lap-edge-cloud

# Pinned image tags (avoid version drift / surprise breakage)
KAFKA_IMAGE=apache/kafka:3.7.0
HADOOP_NAMENODE_IMAGE=bde2020/hadoop-namenode:2.0.0-hadoop3.2.1-java8
HADOOP_DATANODE_IMAGE=bde2020/hadoop-datanode:2.0.0-hadoop3.2.1-java8
REDIS_IMAGE=redis:7-alpine

# Spark / Kafka connector versions used by the placement engine (local mode).
# Must match the bundled Spark version inside the python:3.10 + pyspark image.
SPARK_VERSION=3.5.1
SCALA_VERSION=2.12
